{
  "description": "Verible auto-fix and auto-format hooks for Verilog/SystemVerilog files",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/verible-autofix.py"
          },
          {
            "type": "command",
            "command": "python ${CLAUDE_PLUGIN_ROOT}/hooks/verible-format.py"
          }
        ]
      }
    ]
  }
}
